{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user, their plan, and AI usage limits.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "practitioner"] },
        "aiUsageCount": { "type": "integer" },
        "lastUsageReset": { "type": "string", "format": "date-time" },
        "businessName": { "type": "string" },
        "businessGstin": { "type": "string" },
        "lastPaymentId": { "type": "string" }
      },
      "required": ["uid", "email", "plan", "aiUsageCount"]
    },
    "Invoice": {
      "title": "GST Invoice",
      "description": "Tax invoice generated by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "businessName": { "type": "string" },
        "businessGstin": { "type": "string" },
        "clientName": { "type": "string" },
        "clientGstin": { "type": "string" },
        "totalAmount": { "type": "number" },
        "totalGst": { "type": "number" },
        "grandTotal": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "amount": { "type": "number" },
              "gstRate": { "type": "number" }
            }
          }
        }
      },
      "required": ["userId", "invoiceNumber", "date", "businessName", "clientName", "items"]
    },
    "AIUsageLog": {
      "title": "AI Tool Usage Log",
      "description": "Record of an AI tool execution for tracking usage limits.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "tool": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "prompt": { "type": "string" }
      },
      "required": ["userId", "tool", "timestamp", "prompt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Mapping of Firebase Auth UIDs to user profiles."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of GST invoices."
    },
    "/ai_usage_logs/{logId}": {
      "schema": "AIUsageLog",
      "description": "Audit trail for AI interactions."
    }
  }
}
